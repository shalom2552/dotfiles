#!/bin/bash
# ~/.local/bin/tmux-dev.sh

SESSION="Dev"
DIR="${PWD:-$HOME}"

# Attach if already exists
tmux has-session -t $SESSION 2>/dev/null && tmux attach -t $SESSION && exit

# Window 1: Neovim
tmux new-session -d -s $SESSION -n "Editor" -c "$DIR"
tmux send-keys -t $SESSION:1 "nvim" C-m

# Window 2: Terminal (split into two panes)
tmux new-window -t $SESSION -n "Terminal" -c "$DIR"
tmux split-window -h -t $SESSION:2 -c "$DIR"

# Window 3: Git
tmux new-window -t $SESSION -n "Git" -c "$DIR"
tmux send-keys -t $SESSION:3 "lazygit" C-m

# Focus on editor
tmux select-window -t $SESSION:1

tmux attach -t $SESSION
