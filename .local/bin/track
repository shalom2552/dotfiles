#!/usr/bin/env bash
set -e

DOTFILES_DIR="$HOME/dotfiles"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

info()  { echo -e "${GREEN}[INFO]${NC} $1"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

# ---------------------------------------------------
# Usage
# ---------------------------------------------------
usage() {
    echo "Usage: track <file-or-folder> [file2] [file3] ..."
    echo ""
    echo "Moves config files or folders into ~/dotfiles,"
    echo "symlinks them back via Stow, and commits."
    echo ""
    echo "Examples:"
    echo "  track file"
    echo "  track ~/.bashrc"
    echo "  track ~/.config/fastfetch"
    echo "  track ~/.config/app1 ~/.config/app2"
    exit 1
}

[ $# -eq 0 ] && usage

# ---------------------------------------------------
# Tracking loop
# ---------------------------------------------------
TRACKED=()

for arg in "$@"; do
    SOURCE="$(realpath "$arg")"

    # Validate
    [ ! -e "$SOURCE" ] && { warn "Not found: $SOURCE, skipping..."; continue; }
    [ -L "$SOURCE" ] && { warn "Already a symlink: $SOURCE, skipping..."; continue; }
    [[ "$SOURCE" != "$HOME"* ]] && { warn "Must be under \$HOME: $SOURCE, skipping..."; continue; }
    [[ "$SOURCE" == "$DOTFILES_DIR"* ]] && { warn "Already tracked: ~/${SOURCE#$HOME/}, skipping..."; continue; }

    # Calculate relative path from $HOME
    REL_PATH="${SOURCE#$HOME/}"
    DEST="$DOTFILES_DIR/$REL_PATH"

    # Check if already tracked
    [ -e "$DEST" ] && { warn "Already tracked: $REL_PATH, skipping..."; continue; }

    # Move into dotfiles repo
    info "Moving $REL_PATH into dotfiles..."
    mkdir -p "$(dirname "$DEST")"
    mv "$SOURCE" "$DEST"

    TRACKED+=("$REL_PATH")
done

# Check if anything added
[ ${#TRACKED[@]} -eq 0 ] && { warn "Nothing new to track."; exit 0; }

# ---------------------------------------------------
# Restow to create symlinks
# ---------------------------------------------------
info "Restowing..."
cd "$DOTFILES_DIR"
stow -R .

# Verify symlinks
for REL_PATH in "${TRACKED[@]}"; do
    if [ -L "$HOME/$REL_PATH" ]; then
        info "Symlinked: $REL_PATH"
    else
        warn "Symlink not created for: $REL_PATH — check stow output"
    fi
done

# ---------------------------------------------------
# Commit
# ---------------------------------------------------
echo ""
TRACKED_LIST=$(printf ", %s" "${TRACKED[@]}")
TRACKED_LIST="${TRACKED_LIST:2}"

read -rp "Commit message [feat(track): add $TRACKED_LIST]: " MSG
MSG="${MSG:-feat(track): add $TRACKED_LIST}"

cd "$DOTFILES_DIR"
for REL_PATH in "${TRACKED[@]}"; do
    git add "$REL_PATH"
done
git commit -m "$MSG"

read -rp "Push? [Y/n]: " PUSH
if [[ ! "$PUSH" =~ ^[Nn]$ ]]; then
    git push
fi

info "Done!"
