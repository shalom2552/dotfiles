#!/usr/bin/env bash
set -e

# ── Stage files ─────────────────────────────────────────────────────────────

# Show already-staged files (informational)
STAGED=$(git diff --cached --name-only)
if [[ -n "$STAGED" ]]; then
  echo "Already staged:"
  echo "$STAGED" | sed 's/^/  ✔ /'
  echo
fi

# Unstaged + untracked files → fzf multiselect
UNSTAGED=$(git ls-files --modified --others --exclude-standard)
if [[ -n "$UNSTAGED" ]]; then
  TO_ADD=$(echo "$UNSTAGED" | fzf \
    --multi \
    --prompt="Stage files > " \
    --header="TAB to select, ENTER to confirm, ESC to skip" \
    --preview="git diff --color=always {} 2>/dev/null || cat {}")

  [[ -n "$TO_ADD" ]] && echo "$TO_ADD" | xargs git add
fi

# Abort if nothing staged
if git diff --cached --quiet; then
  echo "Nothing staged. Aborting."
  exit 1
fi

# ── Commit ───────────────────────────────────────────────────────────────────

TYPE=$(gum choose "fix" "feat" "docs" "style" "refactor" "test" "chore" "revert")

SCOPE=$(gum input --placeholder "scope (optional)")
[[ -n "$SCOPE" ]] && SCOPE="($SCOPE)"

SUMMARY=$(gum input --value "$TYPE$SCOPE: " --placeholder "Summary of this change")

DESCRIPTION=$(gum write --placeholder "Details of this change (optional)")

gum confirm "Commit changes?" && git commit -m "$SUMMARY" ${DESCRIPTION:+-m "$DESCRIPTION"}

gum confirm "Push to cloud?" && git push

