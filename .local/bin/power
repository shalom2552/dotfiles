#!/usr/bin/env bash
# ~/.local/bin/power
# Author: Gemini
# Date:   2026-04-18
#
# Unified power menu powered by fzf.
#
# Usage: power [options] [query]
#
# Options:
#   -p, --print   Print the command instead of executing it.
#   -h, --help    Show this help message.

set -uo pipefail

# ==== COLORS (Tokyo Night) ====

C_BLUE='\x1b[38;2;122;162;247m'
C_CYAN='\x1b[38;2;125;207;255m'
C_YELLOW='\x1b[38;2;224;175;104m'
C_PURPLE='\x1b[38;2;187;154;247m'
C_ORANGE='\x1b[38;2;255;158;100m'
C_RED='\x1b[38;2;247;118;142m'
C_RESET='\x1b[0m'

# ==== ARGS ====

usage() {
    cat <<EOF
Usage: power [options] [query]

Fuzzy system power menu.

Options:
  -p, --print     Print the selected command instead of executing.
  -h, --help      Show this help message.

Arguments:
  query           (Optional) Initial search string. If only one match
                  exists, it is selected automatically.
EOF
}

PRINT_MODE=false
QUERY=""

for arg in "$@"; do
    case "$arg" in
        -p|--print) PRINT_MODE=true ;;
        -h|--help)  usage; exit 0 ;;
        -*) echo "Unknown option: $arg" >&2; usage >&2; exit 1 ;;
        *)  [[ -z "$QUERY" ]] && QUERY="$arg" ;;
    esac
done

# ==== ACTIONS ====

LOCK="Lock"
LOGOUT="Logout"
SUSPEND="Suspend"
REBOOT="Reboot"
SHUTDOWN="Shutdown"

# Format: "Icon|Color|Label|Command"
# Symbols: ¾░īŠ Lock, ¾░Ś╝ Logout, ¾░¢ö Suspend, ¾░£ē Reboot, ¾░Éź Shutdown
ACTIONS=(
    "¾░īŠ|${C_BLUE}|${LOCK}|loginctl lock-session || hyprlock"
    "¾░Ś╝|${C_YELLOW}|${LOGOUT}|loginctl terminate-user \"$USER\""
    "¾░¢ö|${C_PURPLE}|${SUSPEND}|systemctl suspend"
    "¾░£ē|${C_ORANGE}|${REBOOT}|systemctl reboot"
    "¾░Éź|${C_RED}|${SHUTDOWN}|systemctl poweroff"
)

# ==== HELPERS ====

confirm() {
    printf '\e[?25l\n\n  %b%s%b\n  %bŌØ»%b %s now? %b[Y/n]%b\n ' \
        "$C_YELLOW" "ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ" "$C_RESET" \
        "$C_YELLOW" "$C_RESET" \
        "$1" \
        "$C_BLUE" "$C_RESET" >/dev/tty
    read -r -n 1 reply </dev/tty
    printf '\e[?25h' >/dev/tty
    [[ "${reply,,}" != "n" ]]
}

# ==== PICK ====

list_actions() {
    for entry in "${ACTIONS[@]}"; do
        IFS='|' read -r icon color label cmd <<< "$entry"
        printf "%b%s%b  %-8s\t%s\n" "$color" "$icon" "$C_RESET" "$label" "$cmd"
    done
}

selected=$(list_actions | fzf \
    --ansi \
    --delimiter=$'\t' \
    --with-nth=1 \
    --query="$QUERY" \
    --select-1 \
    --prompt="> " \
    --pointer="Ō¢Č" \
    --marker="Ō£ō" \
    --border-label=" System " \
    --no-info \
    --border=rounded \
    --height=100% \
    --color=fg:#c0caf5,bg:-1,hl:#bb9af7 \
    --color=fg+:#c0caf5,bg+:-1,hl+:#7dcfff \
    --color=info:#7aa2f7,prompt:#7dcfff,pointer:#7dcfff \
) || exit 0

# ==== EXECUTE ====

CONFIRM_LABELS=("$LOGOUT" "$REBOOT" "$SHUTDOWN")

label=$(echo "$selected" | cut -f1 | sed 's/^[^ ]* *//')
cmd=$(echo "$selected" | cut -f2-)

needs_confirm=false
for cl in "${CONFIRM_LABELS[@]}"; do
    [[ "$label" == *"$cl"* ]] && needs_confirm=true && break
done

if [[ -n "$cmd" ]]; then
    if [[ "$PRINT_MODE" == true ]]; then
        echo "$cmd"
    else
        if [[ "$needs_confirm" == true ]]; then
            confirm "$cl" || exit 0
        fi
        bash -c "$cmd"
    fi
fi
