#!/usr/bin/env bash
# ~/.local/bin/launch
# Author: shalom2552
# Date:   2026-04-17
#
# Fuzzy application launcher. Reads installed .desktop entries, presents them
# via fzf, and launches the selection. Works in any terminal on any distro.
#
# Usage: launch [options] [query]
#
# Options:
#   --print       Print the selected .desktop file path instead of launching.
#                 Intended for WM popup wrappers that handle their own dispatch.
#   --refresh     Force-rebuild the app cache and exit.
#   -h, --help    Show this help message.
#
# Behaviour:
#   GUI apps    → launched detached (survives terminal closing)
#   TUI apps    → replace the current shell (exec in-place)
#   Auto-select → if [query] matches exactly one app, it launches immediately.
#
# Cache: app list is cached at /tmp/launch-cache for 24h for fast startup.

set -uo pipefail


# ==== CONSTANTS ====

CACHE_FILE="/tmp/launch-cache"
CACHE_TTL=$((60 * 60 * 24))


# ==== ARGS ====

usage() {
    cat <<EOF
Usage: launch [options] [query]

Fuzzy application launcher over installed .desktop entries.

Options:
  -p, --print     Print selected .desktop path instead of launching.
                  For WM popup wrappers that handle their own dispatch.
  -r, --refresh   Force-rebuild the app cache and exit.
  -h, --help      Show this help message.

Arguments:
  query           (Optional) Initial search string. If only one match 
                  exists, it is selected automatically (--select-1).

Examples:
  launch          # Open interactive picker
  launch firefox  # Search for firefox, run immediately if unique
  launch -p       # Print selected .desktop path to stdout

Behaviour:
  GUI apps  → launched detached (survives terminal closing)
  TUI apps  → replace the current shell (exec in-place)

Cache is stored at $CACHE_FILE and refreshed every 24h.
Inside the picker, ctrl-r clears the cache and reopens.
EOF
}

PRINT_MODE=false
QUERY=""

for arg in "$@"; do
    case "$arg" in
        -p|--print)   PRINT_MODE=true ;;
        -r|--refresh) rm -f "$CACHE_FILE"; echo "Cache cleared."; exit 0 ;;
        -h|--help)    usage; exit 0 ;;
        -*) echo "Unknown option: $arg" >&2; usage >&2; exit 1 ;;
        *)  [[ -z "$QUERY" ]] && QUERY="$arg" ;;
    esac
done


# ==== CACHE ====

cache_is_stale() {
    [[ ! -f "$CACHE_FILE" ]] && return 0
    local age=$(( $(date +%s) - $(stat -c %Y "$CACHE_FILE") ))
    (( age > CACHE_TTL ))
}

if cache_is_stale; then
    IFS=':' read -ra dirs <<< "${XDG_DATA_HOME:-$HOME/.local/share}:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

    {
        for dir in "${dirs[@]}"; do
            app_dir="$dir/applications"
            [[ -d "$app_dir" ]] || continue

            while IFS= read -r -d '' file; do
                # Skip hidden / system-only entries
                grep -q "^NoDisplay=true" "$file" && continue
                grep -q "^Hidden=true"    "$file" && continue

                name=$(grep -m1 "^Name=" "$file" | cut -d= -f2- | tr -d '\t')
                comment=$(grep -m1 "^Comment=" "$file" | cut -d= -f2- | tr -d '\t' || true)
                icon_name=$(grep -m1 "^Icon=" "$file" | cut -d= -f2- | tr -d '\t' || true)
                [[ -n "$name" ]] || continue

                # Resolve icon path
                icon_path=""
                if [[ -n "$icon_name" ]]; then
                    if [[ "$icon_name" == /* ]]; then
                        icon_path="$icon_name"
                    else
                        # Search common icon locations (prioritize 48x48 apps or pixmaps)
                        icon_path=$(find /usr/share/icons/hicolor/48x48/apps /usr/share/pixmaps /usr/share/icons/hicolor/scalable/apps -name "$icon_name.*" -print -quit 2>/dev/null | head -n 1)
                    fi
                fi

                # Color the name (Tokyo Night Green: #9ece6a)
                printf '\x1b[38;2;158;206;106m%s\x1b[0m\t%s\t%s\t%s\n' "$name" "${comment:-}" "$file" "${icon_path:-}"
            done < <(find "$app_dir" -name "*.desktop" -print0 2>/dev/null)
        done
    } | sort -u -t$'\t' -k1,1 > "$CACHE_FILE"
fi


# ==== PICK ====

# Helper script for preview to show both icon and description
PREVIEW_CMD='
    icon={4}
    desc={2}
if [ -n "$desc" ]; then
        echo "$desc"
    else
        echo "No description available"
    fi
'

selected_line=$(
    fzf --ansi \
        --delimiter=$'\t' \
        --nth=1 \
        --with-nth=1 \
        --prompt="launch > " \
        --pointer="▶" \
        --marker="✓" \
        --query="$QUERY" \
        --select-1 \
        --border-label=" Application Launcher " \
        --border-label-pos=center \
        --bind="ctrl-r:execute(rm -f '$CACHE_FILE')+abort" \
        --preview="$PREVIEW_CMD" \
        --preview-window="top:1:wrap:noinfo" \
        --no-info \
        --border=rounded \
        --height=100% \
        --color=fg:#c0caf5,bg:-1,hl:#bb9af7 \
        --color=fg+:#c0caf5,bg+:-1,hl+:#7dcfff \
        --color=info:#7aa2f7,prompt:#7dcfff,pointer:#7dcfff \
    < "$CACHE_FILE"
) || exit 0


# ==== LAUNCH ====

desktop_file=$(printf "%s" "$selected_line" | cut -f3)
app_id="$(basename "$desktop_file" .desktop)"

is_terminal_app=no
grep -q "^Terminal=true" "$desktop_file" && is_terminal_app=yes

# Strip .desktop field codes (%f %F %u %U etc.) from Exec= line
exec_cmd=$(grep -m1 "^Exec=" "$desktop_file" | cut -d= -f2- | sed 's/ %[a-zA-Z]//g')

if $PRINT_MODE; then
    echo "$desktop_file"
    exit 0
fi

if [[ "$is_terminal_app" == "yes" ]]; then
    exec bash -c "$exec_cmd"
else
    (gtk-launch "$app_id" > /dev/null 2>&1 &)
fi
