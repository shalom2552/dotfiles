#!/usr/bin/env bash

# =============================================================================
# ENVIRONMENT
# =============================================================================
_EZA_COMMON=(--icons --group-directories-first --git)
_FD_COMMON=(--hidden --exclude .npm --exclude .bun --exclude .vscode --exclude .rustup --exclude .cache --exclude .git --exclude go)
_FZF_THEME=(--color=dark)
_FZF_LAYOUT=(--pointer=▶ --border=rounded --border-label-pos=center --height=100% --style=full)
_FZF_KEYBINDS=(--bind=ctrl-d:half-page-down,ctrl-u:half-page-up,ctrl-f:preview-half-page-down,ctrl-b:preview-half-page-up,ctrl-/:toggle-preview,ctrl-a:select-all,ctrl-space:toggle,alt-d:deselect-all)
_FZF_FILE_PREVIEW='bat --style=numbers --color=always --line-range :500 {}'

# =============================================================================
# ALIASES
# =============================================================================

# Core
alias v='nvim'
alias fm='yazi'
alias q='exit'
alias zz='cdi'

# Replacements
alias ls="eza -G ${_EZA_COMMON[*]}"
alias la="eza -a ${_EZA_COMMON[*]}"
alias ll="eza -l --header ${_EZA_COMMON[*]}"
alias lsa="eza -al --header ${_EZA_COMMON[*]}"
alias tree="eza -T --icons --git"
alias df='duf'

# Globals (zsh only)
if [ -n "$ZSH_VERSION" ]; then
    alias -g G='| grep'
    alias -g L='| less'
    alias -g B='| bat'
    alias -g C='| wc -l'
fi

# Fuzzy tools
alias vf='ff | xargs -r ${EDITOR:-nvim}'
alias bf='ff | xargs -r bat'
alias cf='ff | xargs -r cat'
alias wf='ff | xargs -r wc -l'

# System
alias vol='amixer set Master'
alias mix='pulsemixer'
alias lock='xdg-screensaver lock'
alias matrix='unimatrix -ab -c green -s 96'

# Git
alias ga='git add'
alias gap='git add --patch'
alias gau='git add --update'
alias gaa='git add --all --verbose'
alias gp='git push'
alias gpl='git pull'
alias gpf='git push --force'
alias gst='git status -u'
alias gdf='git diff'
alias gcm='git commit -m'
alias gco='git checkout'
alias gsw='git switch'
alias lgt='lazygit'

# Tmux
alias t='tmux'
alias ta='tmux attach -t'
alias tls='tmux ls'
alias tk='tmux kill-session -t'
alias tdev='tmux-dev'

# =============================================================================
# FUNCTIONS
# =============================================================================

# open file explorer
n() {
    [ "$1" = "-h" ] && echo "ff [query] [dir] — fuzzy find files; multi-select; preview with bat" && return
    xdg-open "${1:-.}" 2>/dev/null;
}

# Fuzzy file finder
ff() {
    [ "$1" = "-h" ] && echo "ff [query] [dir]  — fuzzy find files; multi-select; preview with bat" && return
    fd --type f "${_FD_COMMON[@]}" "${2:-.}" | fzf --multi \
        "${_FZF_LAYOUT[@]}" \
        --border-label=" Files " \
        --preview="$_FZF_FILE_PREVIEW" \
        --preview-window=right:70%:wrap \
        "${_FZF_KEYBINDS[@]}" \
        "${_FZF_THEME[@]}"
}

# Fuzzy git log diff browser
fdiff() {
    [ "$1" = "-h" ] && echo "fdiff  — browse git log; preview full diff per commit" && return
    git rev-parse --git-dir &>/dev/null || { echo "fdiff: not a git repository" >&2; return 1; }
    git log --oneline --color=always | fzf \
        --ansi \
        --prompt="commit > " \
        --border-label=" Git Log " \
        --preview 'git show --color=always {1}' \
        --preview-window=right:60%:wrap \
        "${_FZF_LAYOUT[@]}" \
        "${_FZF_KEYBINDS[@]}" \
        "${_FZF_THEME[@]}"
}

# Fuzzy process killer
kf() {
    [ "$1" = "-h" ] && echo "kf  — fuzzy kill processes; Space: mark, Enter: kill, Ctrl-K: kill -9" && return
    command ps aux --no-header \
    | sed -E 's/ +/ /g' \
    | fzf --multi \
        --prompt="proc > " \
        --border-label=" Processes " \
        --header="Space: mark  Enter: kill  Ctrl-K: kill -9" \
        --preview '
          echo "PID:     {2}"
          echo "USER:    {1}"
          echo "CPU:     {3}%"
          echo "MEM:     {4}%"
          echo "TTY:     {7}"
          echo "TIME:    {10}"
          echo ""
          echo "Command:"
          echo "{11..}"
        ' \
        --preview-window="right:50%:wrap" \
        --bind="space:toggle" \
        --bind="ctrl-k:execute-silent(echo {+2} | xargs -r kill -9)+reload(command ps aux --no-header | sed -E 's/ +/ /g')" \
        "${_FZF_LAYOUT[@]}" \
        "${_FZF_KEYBINDS[@]}" \
        "${_FZF_THEME[@]}" \
        --ansi \
    | awk '{print $2}' | xargs -r kill
}

# Browse installed packages
pkgf() {
    [ "$1" = "-h" ] && echo "pkgf  — fuzzy browse installed packages; preview package info" && return
    local pkg
    if command -v pacman &> /dev/null; then
        pkg=$(pacman -Q | fzf \
            --prompt="pkg > " \
            --border-label=" Packages " \
            --preview 'pacman -Qi {1} | bat --language=yaml --color=always --style=plain' \
            --preview-window=right:50%:wrap \
            "${_FZF_LAYOUT[@]}" \
            "${_FZF_KEYBINDS[@]}" \
            "${_FZF_THEME[@]}")
        [[ -n "$pkg" ]] && pacman -Qi "${pkg%% *}" | bat --language=yaml --color=always --style=plain --paging=never
    elif command -v apt &> /dev/null; then
        pkg=$(apt list --installed 2>/dev/null | grep -v "^Listing" | fzf \
            --prompt="pkg > " \
            --border-label=" Packages " \
            --preview 'apt-cache show "$(echo {1} | cut -d/ -f1)" | bat --language=yaml --color=always --style=plain' \
            --preview-window=right:50%:wrap \
            "${_FZF_LAYOUT[@]}" \
            "${_FZF_KEYBINDS[@]}" \
            "${_FZF_THEME[@]}")
        [[ -n "$pkg" ]] && apt-cache show "${pkg%%/*}" | bat --language=yaml --color=always --style=plain --paging=never
    else
        echo "Error: Neither pacman nor apt found on this system" >&2
        return 1
    fi
}

# View all shortcuts
alias shortcuts='bat ~/.aliases --color=always --style=plain | grep "alias" | fzf --ansi --border-label=" Aliases "'
alias sc='shortcuts'

